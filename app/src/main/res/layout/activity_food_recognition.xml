<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/apple_bg">

    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/navBar">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- 标题 -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="饮食记录"
            android:textColor="@color/apple_text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:drawableStart="@drawable/ic_restaurant"
            android:drawableTint="@color/apple_accent"
            android:drawablePadding="10dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- 拍照识别按钮 -->
        <Button
            android:id="@+id/btnCapture"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:text="拍照识别"
            android:textColor="@color/apple_text_primary"
            android:textSize="17sp"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:background="@drawable/bg_apple_button"
            android:drawableStart="@drawable/ic_camera"
            android:drawableTint="@color/apple_text_primary"
            android:paddingStart="20dp"
            android:paddingEnd="24dp"
            android:gravity="start|center_vertical"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="28dp" />

        <!-- 识别结果 -->
        <TextView
            android:id="@+id/tvResult"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="点击拍照识别，或手动录入食物"
            android:textColor="@color/apple_text_tertiary"
            android:textSize="14sp"
            android:letterSpacing="-0.01"
            android:padding="16dp"
            android:background="@drawable/bg_apple_card"
            android:drawableStart="@drawable/ic_info_outline"
            android:drawableTint="@color/apple_text_tertiary"
            android:drawablePadding="10dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/btnCapture"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp" />

        <!-- ═══ 手动录入表单（默认隐藏） ═══ -->
        <LinearLayout
            android:id="@+id/manualForm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="@drawable/bg_apple_card"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvResult"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="手动录入"
                android:textColor="@color/apple_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01"
                android:drawableStart="@drawable/ic_edit"
                android:drawableTint="@color/apple_accent"
                android:drawablePadding="8dp"
                android:layout_marginBottom="16dp" />

            <!-- 餐次 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="餐次"
                android:textColor="@color/apple_text_secondary"
                android:textSize="13sp"
                android:letterSpacing="-0.01"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spMealType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_apple_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp" />

            <!-- 食材选择 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="食材"
                android:textColor="@color/apple_text_secondary"
                android:textSize="13sp"
                android:letterSpacing="-0.01"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spFoodPreset"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_apple_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp" />

            <!-- 食物名 -->
            <EditText
                android:id="@+id/etFoodName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/food_name_hint"
                android:textColor="@color/apple_text_primary"
                android:textColorHint="@color/apple_text_tertiary"
                android:background="@drawable/bg_apple_input"
                android:inputType="text"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="12dp" />

            <!-- 重量 -->
            <EditText
                android:id="@+id/etWeightG"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/food_weight_hint"
                android:textColor="@color/apple_text_primary"
                android:textColorHint="@color/apple_text_tertiary"
                android:background="@drawable/bg_apple_input"
                android:inputType="numberDecimal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnSaveManual"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/save_manual"
                android:textColor="@color/apple_text_primary"
                android:textSize="15sp"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:background="@drawable/bg_apple_button"
                android:drawableStart="@drawable/ic_check"
                android:drawableTint="@color/apple_text_primary"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:gravity="start|center_vertical" />
        </LinearLayout>

        <!-- 手动录入入口 -->
        <Button
            android:id="@+id/btnManual"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:text="@string/manual_entry"
            android:textColor="@color/apple_text_primary"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:background="@drawable/bg_apple_button_secondary"
            android:drawableStart="@drawable/ic_edit"
            android:drawableTint="@color/apple_text_primary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:gravity="start|center_vertical"
            app:layout_constraintTop_toBottomOf="@id/manualForm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <include
        android:id="@+id/navBar"
        layout="@layout/include_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
