<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/apple_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="我的"
            android:textColor="@color/apple_text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="24dp" />

        <!-- 档案摘要卡片 -->
        <TextView
            android:id="@+id/tvProfileSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/apple_text_secondary"
            android:textSize="13sp"
            android:letterSpacing="-0.01"
            android:lineSpacingMultiplier="1.5"
            android:padding="16dp"
            android:background="@drawable/bg_apple_card"
            android:layout_marginBottom="24dp" />

        <!-- API Key 设置区 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="API Key（AI 食物识别）"
            android:textColor="@color/apple_text_secondary"
            android:textSize="13sp"
            android:letterSpacing="-0.01"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/etApiKey"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="输入 API Key"
                android:textColor="@color/apple_text_primary"
                android:textColorHint="@color/apple_text_tertiary"
                android:background="@drawable/bg_apple_input"
                android:inputType="text"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <Button
                android:id="@+id/btnSaveKey"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="保存"
                android:textColor="@color/apple_text_primary"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:background="@drawable/bg_apple_button"
                android:layout_marginStart="8dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />
        </LinearLayout>

        <!-- 编辑档案 -->
        <Button
            android:id="@+id/btnEditProfile"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="编辑档案"
            android:textColor="@color/apple_text_primary"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:background="@drawable/bg_apple_button_secondary"
            android:layout_marginTop="8dp" />

        <!-- 返回 -->
        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_back"
            android:textColor="@color/apple_text_primary"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:background="@drawable/bg_apple_button_secondary"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>
