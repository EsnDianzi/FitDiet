<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/apple_bg">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FitDiet"
        android:textColor="@color/apple_text_primary"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="-0.03"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="64dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="个性化健身 &amp; 饮食计划"
        android:textColor="@color/apple_text_tertiary"
        android:textSize="14sp"
        android:letterSpacing="-0.01"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnOnboarding"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="开始引导"
        android:textColor="@color/apple_text_primary"
        android:textSize="17sp"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:background="@drawable/bg_apple_button"
        android:drawableStart="@drawable/ic_account_circle"
        android:drawableTint="@color/apple_text_primary"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="start|center_vertical"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="40dp" />

    <Button
        android:id="@+id/btnFoodRecognition"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="食物识别"
        android:textColor="@color/apple_text_primary"
        android:textSize="17sp"
        android:textAllCaps="false"
        android:background="@drawable/bg_apple_button_secondary"
        android:drawableStart="@drawable/ic_restaurant"
        android:drawableTint="@color/apple_text_primary"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="start|center_vertical"
        app:layout_constraintTop_toBottomOf="@id/btnOnboarding"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btnBattle"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="挑战 Boss"
        android:textColor="@color/apple_danger"
        android:textSize="17sp"
        android:textAllCaps="false"
        android:background="@drawable/bg_apple_button_secondary"
        android:drawableStart="@drawable/ic_fitness_center"
        android:drawableTint="@color/apple_danger"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="start|center_vertical"
        app:layout_constraintTop_toBottomOf="@id/btnFoodRecognition"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="12dp" />

    <com.esn.fitdiet.ui.custom.PixelProgressBar
        android:id="@+id/expBar"
        android:layout_width="0dp"
        android:layout_height="6dp"
        app:fillColor="@color/apple_accent"
        app:layout_constraintTop_toBottomOf="@id/btnBattle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="40dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
