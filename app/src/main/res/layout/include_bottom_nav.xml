<?xml version="1.0" encoding="utf-8"?>
<!-- 通用底部导航栏（5 Tab + Material 图标 + 顶部高亮指示器）。 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/navBar"
    android:layout_width="match_parent"
    android:layout_height="76dp"
    android:orientation="vertical"
    android:background="@color/apple_surface"
    android:elevation="12dp">

    <!-- 顶部高亮指示器：当前 tab 上方的小条 -->
    <View
        android:id="@+id/navIndicator"
        android:layout_width="0dp"
        android:layout_height="0dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="6dp"
        android:paddingBottom="8dp">

        <!-- ═══ 首页 ═══ -->
        <LinearLayout
            android:id="@+id/btnTabHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_tab_home"
                android:contentDescription="@string/tab_home"
                app:tint="@color/apple_text_tertiary"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/tab_home"
                android:textColor="@color/apple_text_tertiary"
                android:textSize="11sp"
                android:letterSpacing="-0.01" />
        </LinearLayout>

        <!-- ═══ 饮食 ═══ -->
        <LinearLayout
            android:id="@+id/btnTabDiet"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_tab_diet"
                android:contentDescription="@string/tab_diet"
                app:tint="@color/apple_text_tertiary"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/tab_diet"
                android:textColor="@color/apple_text_tertiary"
                android:textSize="11sp"
                android:letterSpacing="-0.01" />
        </LinearLayout>

        <!-- ═══ 训练 ═══ -->
        <LinearLayout
            android:id="@+id/btnTabTrain"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_tab_train"
                android:contentDescription="@string/tab_train"
                app:tint="@color/apple_text_tertiary"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/tab_train"
                android:textColor="@color/apple_text_tertiary"
                android:textSize="11sp"
                android:letterSpacing="-0.01" />
        </LinearLayout>

        <!-- ═══ 统计 ═══ -->
        <LinearLayout
            android:id="@+id/btnTabStats"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_tab_stats"
                android:contentDescription="@string/tab_stats"
                app:tint="@color/apple_text_tertiary"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/tab_stats"
                android:textColor="@color/apple_text_tertiary"
                android:textSize="11sp"
                android:letterSpacing="-0.01" />
        </LinearLayout>

        <!-- ═══ 我的 ═══ -->
        <LinearLayout
            android:id="@+id/btnTabProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_tab_profile"
                android:contentDescription="@string/tab_profile"
                app:tint="@color/apple_text_tertiary"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/tab_profile"
                android:textColor="@color/apple_text_tertiary"
                android:textSize="11sp"
                android:letterSpacing="-0.01" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
