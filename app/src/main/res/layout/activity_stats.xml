<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/apple_bg">

    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/navBar">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="数据洞察"
            android:textColor="@color/apple_text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:drawableStart="@drawable/ic_equalizer"
            android:drawableTint="@color/apple_accent"
            android:drawablePadding="10dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp" />

        <!-- ═══ 本周净热量缺口 + 连续打卡（并列卡片）═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/bg_apple_card_top"
                android:layout_marginEnd="1dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="本周净热量缺口"
                    android:textColor="@color/apple_text_tertiary"
                    android:textSize="12sp"
                    android:letterSpacing="-0.01"
                    android:drawableStart="@drawable/ic_local_fire_department"
                    android:drawableTint="@color/apple_text_tertiary"
                    android:drawablePadding="4dp"
                    android:gravity="center_vertical" />

                <TextView
                    android:id="@+id/tvWeeklyDeficit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- kcal"
                    android:textColor="@color/apple_accent"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/bg_apple_card_top"
                android:layout_marginStart="1dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="连续打卡"
                    android:textColor="@color/apple_text_tertiary"
                    android:textSize="12sp"
                    android:letterSpacing="-0.01"
                    android:drawableStart="@drawable/ic_calendar"
                    android:drawableTint="@color/apple_text_tertiary"
                    android:drawablePadding="4dp"
                    android:gravity="center_vertical" />

                <TextView
                    android:id="@+id/tvStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- 天"
                    android:textColor="@color/apple_warning"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═══ 体重曲线 ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="体重曲线"
            android:textColor="@color/apple_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01"
            android:drawableStart="@drawable/ic_track"
            android:drawableTint="@color/apple_accent"
            android:drawablePadding="8dp"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <com.esn.fitdiet.ui.custom.WeightChartView
            android:id="@+id/weightChart"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/bg_apple_card" />

        <!-- ═══ 训练历史 ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="训练历史"
                android:textColor="@color/apple_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01"
                android:drawableStart="@drawable/ic_fitness_center"
                android:drawableTint="@color/apple_accent"
                android:drawablePadding="8dp"
                android:gravity="center_vertical" />

            <TextView
                android:id="@+id/btnAchievements"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="成就勋章"
                android:textColor="@color/apple_accent"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01"
                android:drawableEnd="@drawable/ic_emoji_events"
                android:drawableTint="@color/apple_accent"
                android:drawablePadding="6dp"
                android:gravity="center_vertical"
                android:padding="8dp"
                android:background="@drawable/bg_battle_muscle"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/exerciseContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/tvEmptyExercise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="还没有训练记录，去训练页面发起第一次挑战吧"
            android:textColor="@color/apple_text_tertiary"
            android:textSize="13sp"
            android:letterSpacing="-0.01"
            android:padding="16dp"
            android:background="@drawable/bg_apple_card"
            android:drawableStart="@drawable/ic_info_outline"
            android:drawableTint="@color/apple_text_tertiary"
            android:drawablePadding="10dp"
            android:gravity="center_vertical" />

    </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/navBar"
        layout="@layout/include_bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
